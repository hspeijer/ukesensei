# Supabase (free tier: https://supabase.com)
# Quick setup via CLI (links project, pushes schema, sets Vercel env):
#   yarn setup:cloud
# Grant admin after signing in once:
#   yarn admin:grant your@email.com
# Re-apply schema only:
#   yarn setup:db
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sign-in is anonymous — enable it under
# Supabase → Authentication → Providers → Anonymous Sign-Ins.

# Optional legacy backend (local dev)
VITE_API_URL=http://localhost:3001/api

# DigitalOcean Spaces (S3-compatible object storage) for lesson/session
# recordings. Each user gets their own folder: <bucket>/<userId>/<recordingId>.ext
# Server-side only — never expose the secret key to the browser bundle.
# Setup:
#   doctl spaces keys create <name> --grants 'bucket=<bucket>;permission=readwrite'
#   yarn spaces:create-bucket   (creates the bucket via the S3 API)
#   yarn spaces:cors            (allows browser uploads via presigned URLs)
DO_SPACES_REGION=ams3
DO_SPACES_BUCKET=ukesensei-recordings
DO_SPACES_ACCESS_KEY_ID=your-spaces-access-key
DO_SPACES_SECRET_ACCESS_KEY=your-spaces-secret-key
